# Agentic RAG System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Supabase Configuration (REQUIRED)
# ============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://owqxhpnaaitqxmcblrab.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im93cXhocG5hYWl0cXhtY2JscmFiIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MzcyODQ2NCwiZXhwIjoyMDg5MzA0NDY0fQ.fE094vCF7Mqcdvvw-abvajzPFg4m9K78iGgVYmUINhA

# ============================================================================
# AI Provider Selection
# ============================================================================
# Choose your AI provider: ollama, openai, anthropic, google, groq
# Default: ollama (local, free)
AI_PROVIDER=ollama

# Choose your embedding provider: ollama, openai
# Default: ollama (local, free)
EMBEDDING_PROVIDER=ollama

# ============================================================================
# Ollama Configuration (Local AI - Free)
# ============================================================================
# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# LLM model for agent reasoning
OLLAMA_LLM_MODEL=qwen3.5:4b

# Embedding model
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Ollama API timeout in seconds for long-running operations
OLLAMA_TIMEOUT=300

# ============================================================================
# Cloud Provider API Keys (Optional)
# ============================================================================
# Uncomment and add your API keys when you want to use cloud providers

# OpenAI - Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic - Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Google - Get from: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=...

# Groq - Get from: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# ============================================================================
# Cloud Model Configuration (Only used when provider is active)
# ============================================================================
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_MODEL=gemini-2.0-flash-exp
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# Context Length Configuration (Prevents context length errors)
# ============================================================================
# LLM model context window size in tokens
# Your LLM has 256k tokens = 262144 tokens (plenty of room!)
LLM_CONTEXT_WINDOW=262144

# Embedding model context window size in tokens
# mxbai-embed-large: 512 tokens (this is the constraint)
EMBEDDING_CONTEXT_WINDOW=512

# Maximum tokens for LLM output/response
# With 256k context, we can afford generous outputs
MAX_OUTPUT_TOKENS=2048

# Reserved tokens for system prompt and overhead
CONTEXT_RESERVE_TOKENS=2000

# ============================================================================
# RAG Configuration
# ============================================================================
# Chunk size in tokens (MUST be less than EMBEDDING_CONTEXT_WINDOW - 50)
# Set to 400 to safely fit in 512-token embedding window with buffer
CHUNK_SIZE=400

# Overlap between chunks in tokens (proportional to chunk size)
CHUNK_OVERLAP=50

# Number of similar chunks to retrieve per query
# With 256k LLM context, we can retrieve many chunks (10-20)
TOP_K_RESULTS=30

# Maximum chunks to include in LLM context (prevents overflow)
# With 256k tokens, 100 chunks × 400 tokens = 40000 tokens (only 15% of context!)
# You could go much higher (50-100+) if needed
MAX_CONTEXT_CHUNKS=100

# Minimum similarity score (0.0-1.0, 0.0 = no filter)
MIN_SIMILARITY=0.0

# ============================================================================
# Agent Configuration
# ============================================================================
# Maximum reasoning loop iterations (1-5, 3 recommended)
MAX_AGENT_ITERATIONS=3

# Minimum confidence to provide answer (0.0-1.0, 0.7 recommended)
MIN_CONFIDENCE_THRESHOLD=0.7

# Enable hallucination verification (true/false)
ENABLE_VERIFICATION=true

# Enable streaming responses (experimental)
ENABLE_STREAMING=false

# ============================================================================
# Document Processing
# ============================================================================
# Maximum file size for uploads in MB
MAX_FILE_SIZE_MB=50

# ============================================================================
# API Configuration
# ============================================================================
API_TITLE=Agentic RAG API
API_VERSION=1.0.0
API_PREFIX=

# CORS allowed origins (JSON array format, ["*"] for all)
CORS_ORIGINS=["*"]

# ============================================================================
# Logging & Development
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode for detailed logs
DEBUG_MODE=false
