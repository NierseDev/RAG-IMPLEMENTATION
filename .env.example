# Agentic RAG System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Supabase Configuration (REQUIRED)
# ============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# AI Provider Selection
# ============================================================================
# Choose your AI provider: ollama, openrouter
# Default: ollama (local, free)
AI_PROVIDER=ollama

# Choose your embedding provider: ollama, openai
# Default: ollama (local, free)
EMBEDDING_PROVIDER=ollama

# ============================================================================
# Ollama Configuration (Local AI - Free)
# ============================================================================
# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# LLM model for agent reasoning
# Recommended: qwen3.5:4b (balanced), llama3.2:3b (faster), phi4:14b-q4 (best quality)
OLLAMA_LLM_MODEL=qwen3.5:4b

# Embedding model
# Recommended: mxbai-embed-large (best quality), nomic-embed-text (longer context)
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Ollama API timeout in seconds
OLLAMA_TIMEOUT=300

# ============================================================================
# OpenRouter Configuration (Cloud AI)
# ============================================================================
# Get your API key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Optional: required only when EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# OpenAI embedding model (only used when EMBEDDING_PROVIDER=openai)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# Context Length Configuration
# ============================================================================
# Auto-adjusted based on provider/model, but can be overridden

# LLM model context window size in tokens
# Ollama qwen3.5:4b: 262144 (256k)
# OpenRouter model context window varies by selected model
LLM_CONTEXT_WINDOW=262144

# Embedding model context window size in tokens
# Ollama mxbai-embed-large: 512 tokens
# OpenAI text-embedding-3-small: 8191 tokens
EMBEDDING_CONTEXT_WINDOW=512

# Maximum tokens for LLM output/response
MAX_OUTPUT_TOKENS=2048

# Reserved tokens for system prompt and overhead
CONTEXT_RESERVE_TOKENS=2000

# ============================================================================
# RAG Configuration
# ============================================================================
# Chunk size in tokens (MUST be less than EMBEDDING_CONTEXT_WINDOW - 50)
CHUNK_SIZE=400

# Overlap between chunks in tokens
CHUNK_OVERLAP=50

# Number of similar chunks to retrieve per query
TOP_K_RESULTS=30

# Maximum chunks to include in LLM context
MAX_CONTEXT_CHUNKS=100

# Minimum similarity score (0.0-1.0, 0.0 = no filter)
MIN_SIMILARITY=0.0

# ============================================================================
# Agent Configuration
# ============================================================================
# Maximum reasoning loop iterations (1-5, 3 recommended)
MAX_AGENT_ITERATIONS=3

# Minimum confidence to provide answer (0.0-1.0, 0.7 recommended)
MIN_CONFIDENCE_THRESHOLD=0.7

# Enable hallucination verification (true/false)
ENABLE_VERIFICATION=true

# Enable streaming responses (experimental)
ENABLE_STREAMING=false

# ============================================================================
# Document Processing
# ============================================================================
# Maximum file size for uploads in MB
MAX_FILE_SIZE_MB=50

# ============================================================================
# API Configuration
# ============================================================================
API_TITLE=Agentic RAG API
API_VERSION=1.0.0
API_PREFIX=

# CORS allowed origins (JSON array format, ["*"] for all)
CORS_ORIGINS=["*"]

# ============================================================================
# Logging & Development
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode for detailed logs
DEBUG_MODE=false

# ============================================================================
# PROVIDER SELECTION GUIDE
# ============================================================================
# 
# LOCAL (FREE):
#   AI_PROVIDER=ollama
#   EMBEDDING_PROVIDER=ollama
#   Best for: Development, testing, self-hosted deployments
#   Cost: Free (hardware cost only)
#   Speed: 15-20 tok/sec on Ryzen 5 8600G
#
# CLOUD (OpenRouter):
#   AI_PROVIDER=openrouter
#   OPENROUTER_MODEL=google/gemma-4-31b-it:free
#   EMBEDDING_PROVIDER=openai
#   Best for: Unified cloud routing through a single provider
#
