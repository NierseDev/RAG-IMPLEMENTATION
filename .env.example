# Agentic RAG System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Supabase Configuration (REQUIRED)
# ============================================================================
# Get these from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# AI Provider Selection
# ============================================================================
# Choose your AI provider: ollama, openai, anthropic, google, groq
# Default: ollama (local, free)
AI_PROVIDER=ollama

# Choose your embedding provider: ollama, openai
# Default: ollama (local, free)
EMBEDDING_PROVIDER=ollama

# ============================================================================
# Ollama Configuration (Local AI - Free)
# ============================================================================
# Ollama server URL (default: local)
OLLAMA_BASE_URL=http://localhost:11434

# LLM model for agent reasoning
# Recommended: qwen3.5:4b (balanced), llama3.2:3b (faster), phi4:14b-q4 (best quality)
OLLAMA_LLM_MODEL=qwen3.5:4b

# Embedding model
# Recommended: mxbai-embed-large (best quality), nomic-embed-text (longer context)
OLLAMA_EMBED_MODEL=mxbai-embed-large

# Ollama API timeout in seconds
OLLAMA_TIMEOUT=300

# ============================================================================
# OpenAI Configuration (Cloud AI)
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# OpenAI model selection
# Options: gpt-4o-mini (fast+cheap), gpt-4o (balanced), gpt-4-turbo
# Cost: gpt-4o-mini ($0.15/$0.60 per 1M tokens)
OPENAI_MODEL=gpt-4o-mini

# OpenAI embedding model
# Options: text-embedding-3-small (cheap), text-embedding-3-large (best)
# Cost: $0.02 per 1M tokens for small, $0.13 per 1M tokens for large
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# Anthropic (Claude) Configuration (Cloud AI)
# ============================================================================
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# Anthropic model selection
# Options: claude-3-5-sonnet-20241022 (best), claude-3-5-haiku-20241022 (fast)
# Cost: Sonnet $3/$15 per 1M tokens, Haiku $1/$5 per 1M tokens
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# Google (Gemini) Configuration (Cloud AI)
# ============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=...

# Google model selection
# Options: gemini-2.0-flash-exp (FAST+CHEAP+1M context!), gemini-1.5-pro
# Cost: Flash $0.075/$0.30 per 1M tokens, Pro $1.25/$5 per 1M tokens
GOOGLE_MODEL=gemini-2.0-flash-exp

# ============================================================================
# Groq Configuration (Cloud AI - FASTEST)
# ============================================================================
# Get your API key from: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# Groq model selection
# Options: llama-3.3-70b-versatile (balanced), mixtral-8x7b-32768 (fast)
# Cost: $0.59/$0.79 per 1M tokens
# Speed: 300+ tokens/sec (fastest inference available!)
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# Context Length Configuration
# ============================================================================
# Auto-adjusted based on provider/model, but can be overridden

# LLM model context window size in tokens
# Ollama qwen3.5:4b: 262144 (256k)
# OpenAI gpt-4o-mini: 128000 (128k)
# Anthropic Claude Sonnet: 200000 (200k)
# Google Gemini Flash: 1048576 (1M!)
# Groq Llama 3.3: 128000 (128k)
LLM_CONTEXT_WINDOW=262144

# Embedding model context window size in tokens
# Ollama mxbai-embed-large: 512 tokens
# OpenAI text-embedding-3-small: 8191 tokens
EMBEDDING_CONTEXT_WINDOW=512

# Maximum tokens for LLM output/response
MAX_OUTPUT_TOKENS=2048

# Reserved tokens for system prompt and overhead
CONTEXT_RESERVE_TOKENS=2000

# ============================================================================
# RAG Configuration
# ============================================================================
# Chunk size in tokens (MUST be less than EMBEDDING_CONTEXT_WINDOW - 50)
CHUNK_SIZE=400

# Overlap between chunks in tokens
CHUNK_OVERLAP=50

# Number of similar chunks to retrieve per query
TOP_K_RESULTS=30

# Maximum chunks to include in LLM context
MAX_CONTEXT_CHUNKS=100

# Minimum similarity score (0.0-1.0, 0.0 = no filter)
MIN_SIMILARITY=0.0

# ============================================================================
# Agent Configuration
# ============================================================================
# Maximum reasoning loop iterations (1-5, 3 recommended)
MAX_AGENT_ITERATIONS=3

# Minimum confidence to provide answer (0.0-1.0, 0.7 recommended)
MIN_CONFIDENCE_THRESHOLD=0.7

# Enable hallucination verification (true/false)
ENABLE_VERIFICATION=true

# Enable streaming responses (experimental)
ENABLE_STREAMING=false

# ============================================================================
# Document Processing
# ============================================================================
# Maximum file size for uploads in MB
MAX_FILE_SIZE_MB=50

# ============================================================================
# API Configuration
# ============================================================================
API_TITLE=Agentic RAG API
API_VERSION=1.0.0
API_PREFIX=

# CORS allowed origins (JSON array format, ["*"] for all)
CORS_ORIGINS=["*"]

# ============================================================================
# Logging & Development
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable debug mode for detailed logs
DEBUG_MODE=false

# ============================================================================
# PROVIDER SELECTION GUIDE
# ============================================================================
# 
# LOCAL (FREE):
#   AI_PROVIDER=ollama
#   EMBEDDING_PROVIDER=ollama
#   Best for: Development, testing, self-hosted deployments
#   Cost: Free (hardware cost only)
#   Speed: 15-20 tok/sec on Ryzen 5 8600G
#
# BUDGET CLOUD (<$0.20 per 1M tokens):
#   AI_PROVIDER=groq (FASTEST! 300+ tok/sec)
#   or AI_PROVIDER=google with GOOGLE_MODEL=gemini-2.0-flash-exp (1M context!)
#   EMBEDDING_PROVIDER=ollama (keep local to save costs)
#   Best for: High-volume applications, low cost
#   Cost: ~$0.10-0.80 per 1M tokens
#
# BALANCED CLOUD:
#   AI_PROVIDER=openai with OPENAI_MODEL=gpt-4o-mini
#   EMBEDDING_PROVIDER=openai
#   Best for: General purpose, reliable
#   Cost: ~$0.15-0.60 per 1M tokens
#
# PREMIUM CLOUD (Best Quality):
#   AI_PROVIDER=anthropic with ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
#   EMBEDDING_PROVIDER=openai
#   Best for: Critical applications, lowest hallucination rate
#   Cost: ~$3-15 per 1M tokens
#
